# PyBridge environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# AI Provider Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Telegram (optional — get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Email / Gmail (optional)
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# WhatsApp (optional — phone number for allowlist)
WHATSAPP_NUMBER=

# Security
HMAC_SECRET=change-me-to-something-random
